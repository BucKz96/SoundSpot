APP_NAME=SoundSpot
APP_ENV=production
# Local email delivery: EMAIL_PROVIDER=log
# Render email delivery: EMAIL_PROVIDER=resend
# Production frontend URL should point to Vercel, for example:
# FRONTEND_URL=https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:5173
EMAIL_PROVIDER=log
EMAIL_FROM=SoundSpot <noreply@example.com>
RESEND_API_KEY=
# Optional: comma-separated extra origins. FRONTEND_URL is added automatically.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://soundspot:soundspot@localhost:5432/soundspot
JWT_SECRET_KEY=change_me_in_dev
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Leave empty to use lax locally and none in production.
AUTH_COOKIE_SAMESITE=
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
TICKETMASTER_API_KEY=your_ticketmaster_api_key
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
OPENAGENDA_API_KEY=your_openagenda_public_api_key
OPENAGENDA_AGENDA_UIDS=
OPENAGENDA_SEARCH_AGENDA_UIDS=
OPENAGENDA_CITY_SEARCH_MAX_EVENTS=50
OPENAGENDA_CITY_SEARCH_MAX_AGENDAS=5
DISCOVERY_OPENAGENDA_MAX_EVENTS=100
DISCOVERY_OPENAGENDA_AGENDA_UIDS=472484,3286118
